{
  "name": "my-vite-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "npm run build && electron .",
    "build": "vite build",
    "dist": "electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourdomain.myapp",
    "productName": "my-vite-app",
     "publish": {
    "provider": "github",
    "owner": "Tawan47",
    "repo": "pos-desktop-app"
  },
    "files": [
      "main.cjs",
      "preload.js",
      "shop-logo.png",
      "backend-nest/dist/**/*",
      "frontend-next/.next/**/*"
    ],
    "extraResources": [
      {
        "from": "./inventory.db",
        "to": "inventory.db"
      },
      {
        "from": "./backend-nest/dist",
        "to": "backend-nest/dist"
      },
      {
        "from": "./resources",
        "to": "resources"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
