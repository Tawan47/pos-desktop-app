generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        Int        @id @default(autoincrement())
  barcode   String     @unique
  name      String
  brand     String?
  size      String?
  color     String?
  price     Float
  quantity  Int
  saleItems         SaleItem[]
}

model Sale {
  id            Int        @id @default(autoincrement())
  invoiceNumber String     @unique
  paymentMethod String?
  subtotal      Float
  discount      Float      @default(0)
  extraCost     Float      @default(0)
  total         Float
  date          String     // Keeping as string to match old SQLite TEXT format, or DateTime if migrated correctly
  items         SaleItem[]
}

model SaleItem {
  id         Int     @id @default(autoincrement())
  sale_id    Int
  product_id Int?
  name       String?
  price      Float?
  qty        Int?
  
  sale       Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)
}

model QuickService {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
}
